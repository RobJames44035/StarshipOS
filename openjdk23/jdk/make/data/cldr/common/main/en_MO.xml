<!DOCTYPE ldml SYSTEM "../../common/dtd/ldml.dtd">
<ldml>
	<identity>
		<version number="$Revision$"/>
		<language type="en"/>
		<territory type="MO"/>
	</identity>
	<dates>
		<timeZoneNames>
			<metazone type="Hong_Kong">
				<short>
					<generic>HKT</generic>
					<standard>HKT</standard>
					<daylight>HKST</daylight>
				</short>
			</metazone>
			<metazone type="Macau">
				<short>
					<generic>MST</generic>
					<standard>MST</standard>
					<daylight>MDT</daylight>
				</short>
			</metazone>
		</timeZoneNames>
	</dates>
	<numbers>
		<currencies>
			<currency type="MOP">
				<symbol>MOP$</symbol>
			</currency>
		</currencies>
	</numbers>
</ldml>
