<!DOCTYPE ldml SYSTEM "../../common/dtd/ldml.dtd">
<ldml>
	<identity>
		<version number="$Revision$"/>
		<language type="ko"/>
		<territory type="CN"/>
	</identity>
	<dates>
		<calendars>
			<calendar type="gregorian">
				<timeFormats>
					<timeFormatLength type="full">
						<timeFormat>
							<pattern>zzzz HH:mm:ss</pattern>
							<datetimeSkeleton>HHmmsszzzz</datetimeSkeleton>
						</timeFormat>
					</timeFormatLength>
					<timeFormatLength type="long">
						<timeFormat>
							<pattern>z HH:mm:ss</pattern>
							<datetimeSkeleton>HHmmssz</datetimeSkeleton>
						</timeFormat>
					</timeFormatLength>
					<timeFormatLength type="medium">
						<timeFormat>
							<pattern>HH:mm:ss</pattern>
							<datetimeSkeleton>HHmmss</datetimeSkeleton>
						</timeFormat>
					</timeFormatLength>
					<timeFormatLength type="short">
						<timeFormat>
							<pattern>HH:mm</pattern>
							<datetimeSkeleton>HHmm</datetimeSkeleton>
						</timeFormat>
					</timeFormatLength>
				</timeFormats>
			</calendar>
		</calendars>
	</dates>
</ldml>
