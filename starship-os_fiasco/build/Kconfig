
mainmenu "Fiasco configuration"

# generic options that might be selected by platforms etc.
config HAS_FPU_OPTION
	bool

config HAS_LAZY_FPU
	bool

config HAS_VIRT_OBJ_SPACE_OPTION
	bool

config HAS_SERIAL_OPTION
	bool

config HAS_WATCHDOG_OPTION
	bool

config HAS_JDB_DISASM_OPTION
	bool

config HAS_JDB_GZIP_OPTION
	bool

config HAS_IOMMU_OPTION
	bool

config HAS_MP_OPTION
	bool

config HAS_COV_OPTION
	bool

config HAS_PLAT_AMP_OPTION
	bool

config HAS_CPU_VIRT
	bool

config HAS_IRQ_DIRECT_INJECT_OPTION
	bool

config HAS_CPU_AMP_OPTION
	bool

config HAS_CPU_MPU
	bool

config HAS_SYNC_CLOCK
	bool

config HAS_ONE_SHOT
	bool

config HAS_TICKLESS_IDLE
	bool

################################################################################
menu "Target configuration"
# Platform-dependent options.
################################################################################

choice
	prompt "Architecture"
	default AMD64

#  ARCH_CHOICE
config AMD64
	bool "AMD64 processor family"
	select HAS_VIRT_OBJ_SPACE_OPTION
	select HAS_JDB_DISASM_OPTION
	select HAS_JDB_GZIP_OPTION
	select HAS_COV_OPTION
	select BIT64
	select FPU
	select HAS_FPU_OPTION
	select HAS_LAZY_FPU
	select HAS_SYNC_CLOCK if (!MP || TSC_UNIFIED)
	select HAS_ONE_SHOT if SYNC_CLOCK && SCHED_APIC

config ARM
	bool "ARM processor family"
	select BIT32 if !BIT64
	select HAS_FPU_OPTION
	select HAS_COV_OPTION
	select FPU if CPU_VIRT
	select ARM_LPAE if MMU && (CPU_VIRT || BIT64)
	select HAS_SERIAL_OPTION
	select HAS_JDB_DISASM_OPTION
	select HAS_JDB_GZIP_OPTION
	select HAS_VIRT_OBJ_SPACE_OPTION if ARM_V6PLUS && !CPU_VIRT && !ARM_1176_CACHE_ALIAS_FIX
	select HAS_LAZY_FPU
	select HAS_SYNC_CLOCK if USE_GENERIC_TIMER
	select HAS_ONE_SHOT if SYNC_CLOCK
	select HAS_TICKLESS_IDLE
	select HAS_IRQ_DIRECT_INJECT_OPTION

config IA32
	bool "Intel IA-32 processor family"
	select BIT32
	select HAS_VIRT_OBJ_SPACE_OPTION
	select HAS_JDB_DISASM_OPTION
	select HAS_JDB_GZIP_OPTION
	select FPU
	select HAS_FPU_OPTION
	select HAS_LAZY_FPU
	select HAS_SYNC_CLOCK if (!MP || TSC_UNIFIED)
	select HAS_ONE_SHOT if SYNC_CLOCK && SCHED_APIC

config MIPS
	bool "MIPS processor family"
	select HAS_FPU_OPTION
	select HAS_SERIAL_OPTION
	select HAS_CPU_VIRT
	select HAS_LAZY_FPU
	select HAS_JDB_DISASM_OPTION

config PPC32
	bool "PowerPC 32 processor family (Caution: INCOMPLETE!)"
	depends on EXPERIMENTAL && "$(INCLUDE_PPC32)"
	select CONTEXT_4K
	select BIG_ENDIAN
	select HAS_SERIAL_OPTION
	select BIT32
	help
		PPC32 testing version, mainly for MPC5200 (603e). Currently,
		there is no support whatsoever.

config RISCV
	bool "RISC-V processor family"
	select HAS_SERIAL_OPTION
	select HAS_JDB_DISASM_OPTION
	select HAS_LAZY_FPU
	select HAS_SYNC_CLOCK
	select HAS_ONE_SHOT if SYNC_CLOCK
	select HAS_TICKLESS_IDLE

config SPARC
	bool "SPARC v8 processor family (Caution: EXPERIMENTAL)"
	depends on EXPERIMENTAL && "$(INCLUDE_SPARC)"
	select BIT32
	select CONTEXT_4K
	select HAS_SERIAL_OPTION
	help
		SPARC v8 is supposed to run on the LEON3 platform.
		It is unsupported at the moment.

endchoice

config BIG_ENDIAN
	bool

choice
	prompt "Platform"
# ARCH_DEFAULT_PF
	default PF_PC  if AMD64
	default PF_ARM_VIRT  if ARM
	default PF_PC  if IA32
	default PF_MALTA  if MIPS
	default PF_MPC52XX  if PPC32
	default PF_RISCV_VIRT  if RISCV
	default PF_LEON3  if SPARC

# PF_CHOICE
