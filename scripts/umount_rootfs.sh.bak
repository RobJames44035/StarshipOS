#!/bin/sh

# Exit immediately on errors
set -e

# Logging functions for cleaner output
log() {
  echo "[INFO] $1"
}

log_error() {
  echo "[ERROR] $1" >&2
}

# Variables
mount_dir="/mnt/rootfs"

# Check if /mnt/rootfs is mounted
if mountpoint -q "$mount_dir"; then
  log "Unmounting $mount_dir..."
  if ! sudo umount -f "$mount_dir"; then
    log_error "Failed to unmount $mount_dir. You may need to manually check the mount status."
    exit 1
  fi
else
  log "$mount_dir is not mounted. Skipping unmount step."
fi

# Find and remove the loop device associated with the disk image
disk_image=$(losetup -a | grep "$mount_dir" | awk -F':' '{print $1}')
if [ -n "$disk_image" ]; then
  log "Detaching loop device $disk_image..."
  if ! sudo losetup -d "$disk_image"; then
    log_error "Failed to detach loop device $disk_image. You may need to reboot the system if the loop device is busy."
    # Offer the user the option to reboot
    echo "The loop device $disk_image could not be detached. A system reboot may resolve the issue."
    echo "Do you wish to reboot now? (y/n) [default: n]: "
    read -r response
    response=${response:-n}
    if [ "$response" = "y" ] || [ "$response" = "Y" ]; then
      log "Rebooting the system now..."
      sudo reboot
    else
      log "User declined to reboot. Exiting without reboot."
      exit 1
    fi
  fi
else
  log "No loop device found associated with $mount_dir. Skipping detach step."
fi

# Remove the mount directory if it exists
if [ -d "$mount_dir" ]; then
  log "Deleting $mount_dir..."
  if ! sudo rm -rf "$mount_dir"; then
    log_error "Failed to delete $mount_dir. Check permissions or manually clean up."
    exit 1
  fi
else
  log "$mount_dir does not exist. No cleanup needed."
fi

log "Unmounting and cleanup completed successfully."
